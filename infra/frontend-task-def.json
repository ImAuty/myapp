{
  "family": "myapp-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::743334887511:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "743334887511.dkr.ecr.ap-northeast-1.amazonaws.com/myapp-frontend:latest",
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "environment": [
        {
          "name": "API_BASE_URL_INTERNAL",
          "value": "http://backend.myapp.local:8080"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/myapp-frontend",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ]
}
